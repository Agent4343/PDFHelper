# Required for AI-powered search
ANTHROPIC_API_KEY=sk-ant-...

# API key to protect your endpoints (generate a random string)
PDF_HELPER_API_KEY=your-secret-api-key-here

# Optional: PostgreSQL connection (Railway sets this automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: restrict CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://yourfrontend.com

# Optional: restrict allowed hosts
# ALLOWED_HOSTS=yourapp.railway.app

# Optional: set to "production" to disable /docs endpoint
# ENVIRONMENT=production

# Optional: max upload size in MB (default 20)
# MAX_FILE_SIZE_MB=20

# Optional: max files per upload request (default 20)
# MAX_FILES_PER_REQUEST=20
