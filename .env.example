# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================

# Anthropic API key for AI-powered search
ANTHROPIC_API_KEY=sk-ant-...

# API key to protect your endpoints — nobody can access without this
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PDF_HELPER_API_KEY=your-secret-api-key-here

# Encryption key for files at rest — PDFs are encrypted on disk
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Set to "production" to enforce all security (required keys, HTTPS, locked CORS)
ENVIRONMENT=production

# =============================================================================
# OPTIONAL
# =============================================================================

# PostgreSQL connection (Railway sets this automatically when you add the plugin)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Restrict CORS origins (comma-separated). Blocks all cross-origin in production if empty.
# ALLOWED_ORIGINS=https://yourfrontend.com

# Restrict allowed hostnames
# ALLOWED_HOSTS=yourapp.railway.app

# Max upload size in MB (default 20)
# MAX_FILE_SIZE_MB=20

# Max files per upload request (default 20)
# MAX_FILES_PER_REQUEST=20

# Auto-delete uploads older than this many hours (default 72, set 0 to disable)
# AUTO_CLEANUP_HOURS=72

# Audit log file path (logs also go to stdout by default)
# AUDIT_LOG_FILE=/var/log/pdfhelper_audit.log

# OCR DPI for scanned PDFs (default 200). Higher = more accurate but slower.
# 150 = fast, 200 = balanced, 300 = high quality
# OCR_DPI=200

# Max parallel threads for OCR processing (default 4)
# OCR_WORKERS=4
